                <mxCell id="hTY25d77OcBwYdx7Al8F-114" value="TO-DO&lt;div&gt;Aggiungere trigger di controllo affinchè la quantità richiesta da una attività sia effettivamente prevista nell&#39;elenco dei materiali (tenendo conto dei riutilizzi)&lt;/div&gt;" style="whiteSpace=wrap;html=1;fillColor=#b0e3e6;strokeColor=#0e8088;" parent="hTY25d77OcBwYdx7Al8F-1" vertex="1">
