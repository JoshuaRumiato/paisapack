        <mxCell id="YcKRzjyWkli9Ld7TOlqu-64" parent="1" style="rhombus;whiteSpace=wrap;html=1;" value="PARTECIPA" vertex="1">
          <mxGeometry height="80" width="80" x="-175.5" y="1154" as="geometry" />
        </mxCell>
        <mxCell id="YcKRzjyWkli9Ld7TOlqu-65" parent="1" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=middle;rounded=0;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="&lt;blockquote style=&quot;margin: 0 0 0 40px; border: none; padding: 0px;&quot;&gt;&lt;span style=&quot;background-color: light-dark(rgb(255, 255, 255), transparent);&quot;&gt;&lt;b style=&quot;font-size: 25px; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;NOTE&lt;/b&gt;&lt;/span&gt;&lt;/blockquote&gt;&lt;blockquote style=&quot;margin: 0 0 0 40px; border: none; padding: 0px;&quot;&gt;&lt;br&gt;&lt;/blockquote&gt;&lt;blockquote style=&quot;margin: 0 0 0 40px; border: none; padding: 0px;&quot;&gt;&lt;br&gt;&lt;/blockquote&gt;&lt;blockquote style=&quot;margin: 0 0 0 40px; border: none; padding: 0px;&quot;&gt;&lt;span style=&quot;background-color: light-dark(rgb(255, 255, 255), transparent);&quot;&gt;&lt;span style=&quot;font-size: 20px; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;TUTTE LE SQUADRE PARTECIPANO A TUTTE LE ATTIVITÀ DI ROUTINE&lt;/span&gt;&lt;/span&gt;&lt;/blockquote&gt;&lt;blockquote style=&quot;margin: 0 0 0 40px; border: none; padding: 0px;&quot;&gt;&lt;span style=&quot;background-color: light-dark(rgb(255, 255, 255), transparent);&quot;&gt;&lt;span style=&quot;font-size: 20px;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;font-size: 20px; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;SALVIAMO SOLO I PUNTEGGI CUMULATI (TOTALI) DELLE SQUADRE&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 20px; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/span&gt;&lt;/blockquote&gt;&lt;blockquote style=&quot;margin: 0 0 0 40px; border: none; padding: 0px;&quot;&gt;&lt;span style=&quot;background-color: light-dark(rgb(255, 255, 255), transparent);&quot;&gt;&lt;span style=&quot;font-size: 20px; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;LA SORELLA DI KEVIN NON PARTECIPA AI CAMPI&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 20px; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/span&gt;&lt;/blockquote&gt;&lt;blockquote style=&quot;margin: 0 0 0 40px; border: none; padding: 0px;&quot;&gt;&lt;span style=&quot;background-color: light-dark(rgb(255, 255, 255), transparent);&quot;&gt;&lt;span style=&quot;font-size: 20px; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;SE IN UNA STANZA CI SONO ANIMATI, CI DEVE ESSERE ALMENO UN ANIMATORE&amp;nbsp;&lt;/span&gt;&lt;/span&gt;&lt;/blockquote&gt;&lt;blockquote style=&quot;margin: 0 0 0 40px; border: none; padding: 0px;&quot;&gt;&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); font-size: 20px; background-color: light-dark(rgb(255, 255, 255), transparent);&quot;&gt;REPSONSABILE (TRIGGER)&lt;/span&gt;&lt;/blockquote&gt;&lt;blockquote style=&quot;margin: 0 0 0 40px; border: none; padding: 0px;&quot;&gt;&lt;span style=&quot;background-color: light-dark(rgb(255, 255, 255), transparent);&quot;&gt;&lt;span style=&quot;font-size: 20px; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/span&gt;&lt;/blockquote&gt;&lt;blockquote style=&quot;margin: 0 0 0 40px; border: none; padding: 0px;&quot;&gt;&lt;span style=&quot;background-color: light-dark(rgb(255, 255, 255), transparent);&quot;&gt;&lt;span style=&quot;font-size: 20px; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;TRIGGER PER SESSO IN UNA STANZA&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 20px; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/span&gt;&lt;/blockquote&gt;&lt;blockquote style=&quot;margin: 0 0 0 40px; border: none; padding: 0px;&quot;&gt;&lt;span style=&quot;background-color: light-dark(rgb(255, 255, 255), transparent);&quot;&gt;&lt;span style=&quot;font-size: 20px; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;SE PIÙ ANIMATORI DORMONO NELLA STESSA STANZA, SONO TUTTI E DUE RESPONSABILI&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size: 20px; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/span&gt;&lt;/blockquote&gt;&lt;blockquote style=&quot;margin: 0 0 0 40px; border: none; padding: 0px;&quot;&gt;&lt;span style=&quot;background-color: light-dark(rgb(255, 255, 255), transparent);&quot;&gt;&lt;span style=&quot;font-size: 20px; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;MATERIALI GENERICI E SPECIFICI VENGONO ACCORPATI IN UN&#39;UNICA ENTITÀ E DISTINTI DA UN APPOSITO CAMPO&lt;/span&gt;&lt;/span&gt;&lt;/blockquote&gt;" vertex="1">
