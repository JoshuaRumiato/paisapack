-- ////////////////
-- PERSONE
-- ////////////////

-- PARTECIPANTI
CREATE TABLE Partecipante (
    codice_fiscale CHAR(16) PRIMARY KEY,
    nome VARCHAR(50) NOT NULL,
    cognome VARCHAR(50) NOT NULL,
    -- sesso CHAR(1) CHECK (sesso IN ('M','F')),
    -- data_nascita DATE,
    luogo_nascita VARCHAR(100),
    note TEXT,

    ON DELETE CASCADE
);

-- ANIMATO
CREATE TABLE Animato (
    codice_fiscale FOREIGN KEY REFERENCES Partecipante(codice_fiscale),
    telefono_genitore VARCHAR(20) NOT NULL,
    email_genitore VARCHAR(100) NOT NULL,
    squadra FOREIGN KEY REFERENCES Squadra(nome),

    PRIMARY KEY (codice_fiscale),
    ON DELETE CASCADE
);

-- COLLABORATORE
CREATE TABLE Collaboratore (
    codice_fiscale FOREIGN KEY REFERENCES Partecipante(codice_fiscale),
    email VARCHAR(50) NOT NULL,
    telefono VARCHAR(20),
    valutazione_voto VARCHAR(100),
    valutazione_commento TEXT,

    PRIMARY KEY (codice_fiscale)
);

-- ANIMATORE
CREATE table Animatore (
    codice_fiscale FOREIGN KEY REFERENCES Collaboratore(codice_fiscale),
    ruolo VARCHAR(100) NOT NULL,
    email VARCHAR(50) NOT NULL,
    telefono VARCHAR(20),
    valutazione_voto VARCHAR(100),
    valutazione_commento TEXT,
    capo_campo BOOLEAN NOT NULL default FALSE,

    PRIMARY KEY (codice_fiscale)
);

-- CUOCO
CREATE table Cuoco (
    codice_fiscale FOREIGN KEY REFERENCES Collaboratore(codice_fiscale),
    email VARCHAR(50) NOT NULL,
    telefono VARCHAR(20),
    valutazione_voto VARCHAR(100),
    valutazione_commento TEXT,

    PRIMARY KEY (codice_fiscale)
);

-- SQUADRA
CREATE TABLE Squadra (
    nome VARCHAR(50),
    slogan VARCHAR(20) NOT NULL,
    punteggio INT NOT NULL,
    animatore FOREIGN KEY REFERENCES Animatore(codice_fiscale),

    PRIMARY KEY (nome)
);

-- ////////////////
-- STRUTTURA
-- ///////////////

-- STANZA
create table Stanza (
    numero_stanza INT,
    piano INT NOT NULL,
    posti_letto INT NOT NULL,
    edificio VARCHAR(100) NOT NULL,

    PRIMARY KEY (numero_stanza, edificio)
)

-- ///////////////
-- ALLERGENE
-- ///////////////

-- ALLERGENE
CREATE TABLE Allergene (
    nome VARCHAR(50) PRIMARY KEY,
);

-- ///////////////
-- ATTIVITà
-- ///////////////

-- EXTRA    
CREATE TABLE Extra (
    inizio DATE,
    fine DATE,
    tipo VARCHAR(100) NOT NULL,
    descrizione TEXT,

    PRIMARY KEY (inizio, fine)
);

-- FACCENDA
CREATE table Faccenda (
    inizio DATE,
    fine DATE,
    tipo VARCHAR(100) NOT NULL,
    descrizione TEXT,
    squadra FOREIGN KEY REFERENCES Squadra(nome),

    PRIMARY KEY (inizio, fine)
);

-- ///////////////
-- MATERIALE
-- ///////////////
CREATE TABLE Materiale (
    nome VARCHAR(100) PRIMARY KEY,
    unita_misura VARCHAR(20) NOT NULL,
    autonomia BOOLEAN NOT NULL DEFAULT FALSE,
    numero_utilizzi INT NOT NULL DEFAULT 0,
);

